<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined secondary action with ripple; disabled state dims the outline. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#22FFFFFF">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="@color/gv_surface_stroke" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1.5dp" android:color="@color/gv_accent" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
