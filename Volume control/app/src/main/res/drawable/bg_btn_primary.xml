<?xml version="1.0" encoding="utf-8"?>
<!-- Filled accent CTA with a ripple on press and a clearly dimmed disabled state. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape android:shape="rectangle">
                    <solid android:color="@color/gv_surface_stroke" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/gv_accent" />
                    <corners android:radius="14dp" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
